            <div class="github-stats-wrapper">
                <div class="inner-stat-card">
                    <h4>Praveena32</h4>
                    <div class="stat-row"><span>Total Contributions</span><strong>1,241</strong></div>
                    <div class="stat-row"><span>Public Repos</span><strong>11</strong></div>
                    <div class="stat-row"><span>Followers</span><strong>25</strong></div>
                    <div class="stat-row"><span>Following</span><strong>18</strong></div>
