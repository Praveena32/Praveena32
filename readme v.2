        <h3 class="panel-title"><i class="fa-solid fa-layer-group"></i> Tech Stack</h3>
        <div class="tech-stack-grid">
            <div class="tech-category">
                <h5>Languages</h5>
                <div class="tech-icons">
                    <span class="tech-badge-mini">Java</span>
                    <span class="tech-badge-mini">C++</span>
