<!-- Interactive Engine Logic Script -->
<script>
    // 1. Live Functional Interface Clock
    function updateLiveClock() {
        const clockElement = document.getElementById('live-clock');
        const now = new Date();
        clockElement.textContent = now.toLocaleTimeString('en-US', { hour12: true });
    }
    setInterval(updateLiveClock, 1000);
    updateLiveClock();

    // 2. Automated Contribution Graph Random Color Distributor
    const heatmapGrid = document.getElementById('heatmap-grid');
    const totalCells = 112; // 28 columns x 4 pseudo rows
    
    for (let i = 0; i < totalCells; i++) {
        const cell = document.createElement('div');
        cell.classList.add('graph-cell');
        
        // Random distribution weight factor simulating real git activity
        const weight = Math.random();
        if (weight > 0.85) cell.classList.add('v4');
        else if (weight > 0.65) cell.classList.add('v3');
        else if (weight > 0.45) cell.classList.add('v2');
        else if (weight > 0.25) cell.classList.add('v1');
        
        heatmapGrid.appendChild(cell);
    }
</script>

