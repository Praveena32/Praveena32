        </div>
    </section>

    <!-- CONTENT MODULES SPLIT -->
    <div class="grid-2col">
        <!-- Text About Me Block -->
        <article class="panel">
            <h3 class="panel-title"><i class="fa-regular fa-user"></i> About Me</h3>
